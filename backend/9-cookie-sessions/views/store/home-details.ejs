<%- include('../partials/head') %>
<body class="bg-gray-100">

    <!-- Navbar -->
    <%- include('../partials/nav') %>

    <div class="max-w-5xl mx-auto p-6">

        <!-- Title + Rating -->
        <div class="flex justify-between items-center mb-4">
            <h1 class="text-4xl font-bold text-gray-900"><%= home.houseName %></h1>

            <p class="text-yellow-500 font-semibold text-xl">
                ⭐ <%= home.rating %>
            </p>
        </div>

        <!-- Location -->
        <p class="text-gray-700 mb-6 text-lg">📍 <%= home.location %></p>

        <!-- Main Image -->
        <div class="relative mb-6">
            <img 
                src="<%= home.image || home.photoURL || 'https://via.placeholder.com/400'  %>" 
                alt="home image"
                class="w-full h-[420px] object-cover rounded-xl shadow"
            >

            <!-- Wishlist Heart -->
            <button class="absolute top-4 right-4 bg-white p-3 rounded-full shadow hover:scale-110 transition">
                ❤️
            </button>
        </div>

        <!-- Details Section -->
        <div class="bg-white p-6 rounded-xl shadow">

            <!-- Price -->
            <p class="text-3xl font-bold text-gray-900 mb-4">
                ₹<%= home.price %> 
                <span class="text-gray-500 text-xl font-normal">/ night</span>
            </p>

            <!-- About Section -->
            <h2 class="text-2xl font-semibold text-gray-800 mb-2">About this place</h2>
            <p class="text-gray-700 leading-relaxed mb-6">
                <%= home.description || "A comfortable and modern place to stay with all essential amenities. Book now to enjoy a great experience!" %>
            </p>

            <!-- Book Now Button -->
            <a href="/book/<%= home._id %>"
                class="block text-center bg-red-500 text-white py-3 rounded-xl text-xl hover:bg-red-600 transition">
                Book Now
            </a>

        </div>
    </div>

</body>
</html>