<%- include('../partials/head') %>

<body class="bg-gray-100 min-h-screen flex flex-col">

    <%- include('../partials/nav') %>

    <!-- Form Container -->
    <div class="flex justify-center items-center flex-grow">
        
        <form action="/host/<%=editing?'edit-home' :'add-home'%>" method="post"
              class="bg-white shadow-lg rounded-xl p-8 w-full max-w-md space-y-6">

            <h2 class="text-2xl font-bold text-gray-800 text-center">
                <!-- <%=editing?'Edit your home':'Add Your Home'%> -->
            </h2>

            <!-- Input Field -->
            <input type="hidden" name="id" value="<%=home?home._id:''%>">
            <input 
                type="text" 
                name="houseName" 
                placeholder="Enter name of your home"
                value="<%=home?home.houseName:''%>"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="text" 
                name="price" 
                placeholder="Enter daily rent"
                value="<%=home?home.price:''%>"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="text" 
                name="location" 
                placeholder="location"
                value="<%=home?home.location:''%>"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="text" 
                name="rating" 
                placeholder="Enter rating"
                value="<%=home?home.rating:''%>"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="text" 
                name="photoURL" 
                placeholder="upload photo"
                value="<%=home?home.photoURL:''%>"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="text" 
                name="description" 
                placeholder="Enter description"
                value="<%=home?home.description:''%>"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >

            <!-- Submit Button -->
            <input 
                type="submit" 
                value="<%=editing?'Update Home':'Add home'%>"
                class="w-full bg-red-500 text-white py-3 rounded-lg font-semibold hover:bg-red-600 transition duration-200 cursor-pointer"
            >

        </form>

    </div>

</body>
</html>